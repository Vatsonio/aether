# ============================
# Aether - .gitignore
# ============================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/
.ENV/
env.bak/
venv.bak/

# Environment variables (never commit secrets)
.env
.env.local
.env.*.local
*.env
!config/.env.example

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Logs
*.log
logs/
*.log.*

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.cache

# Docker (optional overrides)
docker-compose.override.yml
docker-compose.*.local.yml

# Node / Frontend build (if you add npm later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js
dist/
build/

# Testing / coverage
.coverage
htmlcov/
.tox/
.nox/
.cache
.pytest_cache/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# pyright
pyrightconfig.json

# Misc
*.pid
*.seed
*.pid.lock
*.tgz
*.zip
*.tar.gz

# Keep example files
!*.example
!config/config.yml.example

# AI personal knowledge file (for Grok / AI assistant only, never commit)
AETHER_PROJECT_KNOWLEDGE.md
.aether-knowledge*
*AI_KNOWLEDGE*
